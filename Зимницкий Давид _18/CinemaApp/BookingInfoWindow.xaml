<Window x:Class="CinemaApp.BookingInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Booking"
        Height="250"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>

        <Storyboard x:Key="PopupAnimation">

            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.5"/>

        </Storyboard>

    </Window.Resources>

    <Grid x:Name="MainGrid"
          Opacity="0">

        <Border Background="#2D2D2D"
                CornerRadius="20"
                Padding="30">

            <StackPanel>

                <TextBlock x:Name="InfoText"
                           FontSize="28"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,20"/>

                <Button Content="OK"
                        Width="120"
                        Height="40"
                        Background="#0078D7"
                        Foreground="White"
                        Click="Button_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>