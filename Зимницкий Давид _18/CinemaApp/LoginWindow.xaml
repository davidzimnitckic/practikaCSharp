<Window x:Class="CinemaApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="420"
        Width="500"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Border Width="350"
                Height="340"
                Background="#2D2D2D"
                CornerRadius="20"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="CINEMA LOGIN"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Логин"
                           Foreground="White"
                           FontSize="16"/>

                <TextBox x:Name="LoginBox"
                         Height="40"
                         FontSize="18"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Пароль"
                           Foreground="White"
                           FontSize="16"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="40"
                             FontSize="18"
                             Margin="0,5,0,25"/>

                <Button Content="ВОЙТИ"
                        Height="45"
                        Background="#0078D7"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="LoginButton_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>