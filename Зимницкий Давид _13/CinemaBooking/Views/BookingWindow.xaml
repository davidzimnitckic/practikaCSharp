<Window x:Class="CinemaBooking.Views.BookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор фильма" Height="300" Width="300">

    <StackPanel Margin="10">

        <TextBlock Text="Выберите фильм:" FontWeight="Bold"/>

        <ListBox x:Name="MoviesList">
            <ListBoxItem Content="Интерстеллар"/>
            <ListBoxItem Content="Начало"/>
            <ListBoxItem Content="Матрица"/>
        </ListBox>

        <Button Content="Далее" Click="Next_Click"/>

    </StackPanel>
</Window>