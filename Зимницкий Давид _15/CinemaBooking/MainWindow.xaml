<Window x:Class="CinemaBooking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cinema" Height="400" Width="400">

    <Window.Resources>

        <!-- Цвет кнопки -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="LightGreen"/>
        </Style>

        <!-- Шаблон места -->
        <DataTemplate x:Key="SeatTemplate">
            <Button Content="{Binding Number}"
                    Command="{Binding DataContext.BookSeatCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBooked}" Value="True">
                                <Setter Property="Background" Value="Gray"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </DataTemplate>

    </Window.Resources>

    <!-- Сетка мест -->
    <ItemsControl ItemsSource="{Binding Seats}"
                  ItemTemplate="{StaticResource SeatTemplate}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Columns="5"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>

</Window>