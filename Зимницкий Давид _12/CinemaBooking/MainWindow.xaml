<Window x:Class="CinemaBooking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кинотеатр" Height="520" Width="750"
        Background="#1e1e2f">

    <!-- 🎨 стиль: текст на кнопках черный -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="15">

        <!-- Заголовок -->
        <TextBlock Text="🎬 Кинотеатр"
                   FontSize="30"
                   Foreground="#FFD700"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Выбор фильма -->
        <ComboBox x:Name="FilmComboBox"
                  Height="35"
                  FontSize="14"
                  Background="#333"
                  Foreground="Black">
            <ComboBoxItem Content="Аватар"/>
            <ComboBoxItem Content="Интерстеллар"/>
            <ComboBoxItem Content="Джокер"/>
        </ComboBox>

        <!-- Экран -->
        <TextBlock Text="ЭКРАН"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,15"
                   FontWeight="Bold"/>

        <!-- Сетка мест -->
        <Border Background="#2a2a40" CornerRadius="10" Padding="10">
            <Grid x:Name="SeatsGrid"/>
        </Border>

        <!-- Кнопка -->
        <Button Content="Забронировать"
                Height="45"
                Margin="0,15,0,0"
                Background="#ff4757"
                Foreground="White"
                FontSize="16"
                FontWeight="Bold"
                Click="Book_Click"/>
    </StackPanel>
</Window>