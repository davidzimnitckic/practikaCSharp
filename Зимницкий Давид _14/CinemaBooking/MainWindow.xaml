<Window x:Class="CinemaBooking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cinema Booking" Height="500" Width="600">

    <Window.Resources>

        <!-- 🔹 DataTemplate (карточка фильма) -->
        <DataTemplate x:Key="MovieTemplate">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="{Binding MovieTitle}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Time}"/>
                    <TextBlock Text="Свободные места:"/>
                    <TextBlock Text="{Binding AvailableSeats}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- 🔹 Стиль кнопки -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightGray" CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <StackPanel Margin="10">

        <!-- 🔹 Фильтр по времени -->
        <ComboBox ItemsSource="{Binding Times}"
                  SelectedItem="{Binding SelectedTime}"
                  Margin="5"/>

        <!-- 🔹 Список фильмов -->
        <ListBox ItemsSource="{Binding Sessions}"
                 ItemTemplate="{StaticResource MovieTemplate}"
                 SelectedItem="{Binding SelectedSession}"
                 Height="250"/>

        <!-- 🔹 Ввод количества билетов (TwoWay) -->
        <TextBox Text="{Binding TicketCount, Mode=TwoWay}"
                 Margin="5"
                 Height="30"/>

        <!-- 🔹 Кнопка -->
        <Button Content="Купить билет"
                Margin="5"
                Height="40"
                Foreground="Black"/>

    </StackPanel>

</Window>