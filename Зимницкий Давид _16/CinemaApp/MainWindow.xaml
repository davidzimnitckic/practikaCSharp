<Window x:Class="CinemaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CinemaApp"
        mc:Ignorable="d"
        Title="CinemaApp"
        Height="720"
        Width="1250"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- DataTemplate -->

        <DataTemplate x:Key="MovieTemplate">

            <Border Background="#2D2D2D"
                    CornerRadius="15"
                    Margin="10"
                    Padding="15">

                <StackPanel>

                    <!-- OneWay Binding -->

                    <TextBlock Text="{Binding Movie.Title}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="{Binding Movie.Genre}"
                               FontSize="16"
                               Foreground="LightGray"
                               Margin="0,5,0,0"/>

                    <TextBlock Text="{Binding Time}"
                               FontSize="16"
                               Foreground="LightBlue"
                               Margin="0,5,0,0"/>

                    <TextBlock Text="{Binding Price}"
                               FontSize="18"
                               Foreground="LightGreen"
                               Margin="0,5,0,0"/>

                </StackPanel>

            </Border>

        </DataTemplate>

        <!-- ControlTemplate -->

        <Style x:Key="CinemaButton"
               TargetType="Button">

            <Setter Property="Background"
                    Value="#0078D7"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="18"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Width"
                    Value="90"/>

            <Setter Property="Height"
                    Value="90"/>

            <Setter Property="Margin"
                    Value="10"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="320"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->

        <StackPanel Grid.Column="0"
                    Margin="20">

            <TextBlock Text="CINEMA APP"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,20"/>

            <!-- FILTER -->

            <TextBlock Text="Фильтр по времени"
                       Foreground="White"
                       FontSize="18"
                       Margin="10"/>

            <TextBox Height="40"
                     FontSize="18"
                     Margin="0,0,0,15"
                     Text="{Binding FilterTime,
                     Mode=TwoWay,
                     UpdateSourceTrigger=PropertyChanged}"/>

            <!-- MOVIES -->

            <ListBox ItemsSource="{Binding Sessions}"
                     ItemTemplate="{StaticResource MovieTemplate}"
                     Background="#1E1E1E"
                     BorderThickness="0"
                     Foreground="White"
                     Height="400"/>

            <!-- TICKET COUNT -->

            <TextBlock Text="Количество билетов"
                       Foreground="White"
                       FontSize="18"
                       Margin="10"/>

            <TextBox Height="40"
                     FontSize="18"
                     Text="{Binding TicketCount,
                     Mode=TwoWay,
                     UpdateSourceTrigger=PropertyChanged}"/>

        </StackPanel>

        <!-- RIGHT PANEL -->

        <ScrollViewer Grid.Column="1"
                      Margin="20">

            <!-- UniformGrid -->

            <UniformGrid Columns="5">

                <ItemsControl ItemsSource="{Binding Seats}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Button Content="{Binding Number}"
                                    Command="{Binding DataContext.BookSeatCommand,
                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">

                                <Button.Style>

                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource CinemaButton}">

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding IsBooked}"
                                                         Value="True">

                                                <Setter Property="Background"
                                                        Value="Red"/>

                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding IsBooked}"
                                                         Value="False">

                                                <Setter Property="Background"
                                                        Value="Green"/>

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>

                                </Button.Style>

                            </Button>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </UniformGrid>

        </ScrollViewer>

    </Grid>

</Window>